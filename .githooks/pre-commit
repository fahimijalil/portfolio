#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED_FILES" ] && exit 0

VIOLATIONS=0

for FILE in $STAGED_FILES; do
  if [[ "$FILE" == ".env" || "$FILE" == *".env.local" || "$FILE" == *".env.production" ]]; then
    echo -e "${RED}[SECURITY] Fichier .env détecté : $FILE${NC}"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi

  if [[ "$FILE" == *.pem || "$FILE" == *.key || "$FILE" == *id_rsa* || "$FILE" == *id_ed25519 ]]; then
    echo -e "${RED}[SECURITY] Clé privée détectée : $FILE${NC}"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi

  if [ -f "$FILE" ]; then
    git diff --cached -- "$FILE" | grep -qE 'AKIA[0-9A-Z]{16}' && {
      echo -e "${RED}[SECURITY] Clé AWS détectée dans : $FILE${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    } || true

    git diff --cached -- "$FILE" | grep -qE 'gh[pousr]_[A-Za-z0-9]{36}' && {
      echo -e "${RED}[SECURITY] Token GitHub détecté dans : $FILE${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    } || true

    git diff --cached -- "$FILE" | grep -qE 'sk-ant-[A-Za-z0-9\-_]{90,}' && {
      echo -e "${RED}[SECURITY] Clé Anthropic détectée dans : $FILE${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    } || true

    git diff --cached -- "$FILE" | grep -qiE '(API_KEY|SECRET|TOKEN|PASSWORD)\s*=\s*[A-Za-z0-9_\-]{20,}' && {
      echo -e "${YELLOW}[WARNING] Pattern secret possible dans : $FILE — vérifie manuellement${NC}"
    } || true
  fi
done

if [ $VIOLATIONS -gt 0 ]; then
  echo -e "\n${RED}Commit bloqué : $VIOLATIONS violation(s) détectée(s).${NC}"
  echo "Corrige avant de committer. En dernier recours : git commit --no-verify (documente pourquoi)."
  exit 1
fi

exit 0
