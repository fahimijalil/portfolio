---
import '../styles/global.css'
interface Props { title?: string }
const { title = 'Portfolio' } = Astro.props
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen font-sans">
    <nav class="border-b border-gray-800 px-6 py-4 flex gap-6 text-sm">
      <a href="/" class="hover:text-white text-gray-400 transition">Accueil</a>
      <a href="/projets" class="hover:text-white text-gray-400 transition">Projets</a>
    </nav>
    <main class="max-w-3xl mx-auto px-6 py-16">
      <slot />
    </main>
  </body>
</html>
